digraph finite_state_machine {
  rankdir=LR;
  size="7"
  node [fontname="times-italic"];
  edge [fontname="times-italic"];
  node [shape = point]; qi
  node [shape = doublecircle]; q1,q2,q3;
  node [shape = circle];
  qi -> q0;
  q0 -> q0 [ label = "a" ];
  q0 -> q2 [ label = "b" ];
  q0 -> q5 [ label = "c" ];
  q1 -> q5 [ label = "a" ];
  q1 -> q2 [ label = "b" ];
  q1 -> q6 [ label = "c" ];
  q2 -> q5 [ label = "a" ];
  q2 -> q1 [ label = "b" ];
  q2 -> q6 [ label = "c" ];
  q3 -> q6 [ label = "a" ];
  q3 -> q0 [ label = "b" ];
  q3 -> q0 [ label = "c" ];
  q4 -> q6 [ label = "a" ];
  q4 -> q3 [ label = "b" ];
  q4 -> q0 [ label = "c" ];
  q5 -> q5 [ label = "a" ];
  q5 -> q1 [ label = "b" ];
  q5 -> q3 [ label = "c" ];
  q6 -> q6 [ label = "a" ];
  q6 -> q1 [ label = "b" ];
  q6 -> q1 [ label = "c" ];
}
