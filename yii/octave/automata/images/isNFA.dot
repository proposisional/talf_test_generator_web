digraph finite_state_machine {
  rankdir=LR;
  size="3"
  node [fontname="times-italic"];
  edge [fontname="times-italic"];
  node [shape = point]; qi
  node [shape = doublecircle]; q2;
  node [shape = circle];
  qi -> q0;
  q0 -> q1 [ label = "a" ];
  q0 -> q1 [ label = "b" ];
  q0 -> q2 [ label = "c" ];
  q1 -> q2 [ label = "a" ];
  q1 -> q0 [ label = "b" ];
  q1 -> q0 [ label = "c" ];
  q2 -> q0 [ label = "a" ];
  q2 -> q2 [ label = "b" ];
  q2 -> q2 [ label = "c" ];
}
