digraph finite_state_machine {
  rankdir=LR;
  size="5"
  node [fontname="times-italic"];
  edge [fontname="times-italic"];
  node [shape = point]; qi
  node [shape = doublecircle]; q3,q4;
  node [shape = circle];
  qi -> q0;
  q0 -> q0 [ label = "|" ];
  q1 -> q1 [ label = "|" ];
  q2 -> q4 [ label = "|" ];
  q3 -> q1 [ label = "|" ];
  q4 -> q0 [ label = "|" ];
}
