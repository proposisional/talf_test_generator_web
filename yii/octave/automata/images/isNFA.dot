digraph finite_state_machine {
  rankdir=LR;
  size="7"
  node [fontname="times-italic"];
  edge [fontname="times-italic"];
  node [shape = point]; qi
  node [shape = doublecircle]; q1,q3;
  node [shape = circle];
  qi -> q0;
  q0 -> q3 [ label = "110" ];
  q4 -> q6 [ label = "*" ];
  q4 -> q4 [ label = "01" ];
  q2 -> q4 [ label = "101" ];
  q3 -> q1 [ label = "*" ];
  q1 -> q4 [ label = "00" ];
  q0 -> q0 [ label = "010" ];
  q1 -> q1 [ label = "11" ];
  q6 -> q6 [ label = "*" ];
  q1 -> q3 [ label = "010" ];
  q6 -> q1 [ label = "*" ];
  q0 -> q3 [ label = "000" ];
}
